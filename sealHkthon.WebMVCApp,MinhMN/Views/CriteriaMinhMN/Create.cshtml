@model CriteriaItemsMinhMN

@{
    ViewData["Title"] = "Thêm tiêu chí";
}

<h1>Thêm Criteria Item</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="CriteriaSetIdMinhMN" class="form-label">Bộ template</label>
                <select asp-for="CriteriaSetIdMinhMN" class="form-select" asp-items="ViewBag.CriteriaSetIdMinhMN">
                    <option value="">-- Chọn bộ template --</option>
                </select>
                <span asp-validation-for="CriteriaSetIdMinhMN" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CriteriaName" class="form-label"></label>
                <input asp-for="CriteriaName" class="form-control" />
                <span asp-validation-for="CriteriaName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Weight" class="form-label">Trọng số (%)</label>
                <input asp-for="Weight" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="Weight" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="MaxScore" class="form-label">Điểm tối đa</label>
                <input asp-for="MaxScore" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="MaxScore" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <input type="submit" value="Lưu" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
